
{
  "entities": {
    "Recording": {
      "title": "Voice Recording",
      "description": "An AI voice recording to be assessed.",
      "type": "object",
      "properties": {
        "title": {
          "type": "string"
        },
        "audioUrl": {
          "type": "string"
        },
        "duration": {
          "type": "string"
        },
        "order": {
          "type": "number",
          "description": "The sequence in which this recording appears in the assessment."
        }
      },
      "required": [
        "title",
        "audioUrl",
        "duration",
        "order"
      ]
    },
    "AssessmentSubmission": {
      "title": "Assessment Submission",
      "description": "A user's evaluation of AI voice recordings.",
      "type": "object",
      "properties": {
        "user": {
          "type": "object",
          "properties": {
            "name": {
              "type": "string"
            },
            "email": {
              "type": "string",
              "format": "email"
            }
          },
          "required": [
            "name",
            "email"
          ]
        },
        "assessments": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "recordingId": {
                "type": "string"
              },
              "rating": {
                "type": "number"
              },
              "feedback": {
                "type": "string"
              }
            }
          }
        },
        "submittedAt": {
          "type": "string",
          "format": "date-time"
        }
      },
      "required": [
        "user",
        "assessments",
        "submittedAt"
      ]
    }
  },
  "auth": {
    "providers": [
      "google.com"
    ]
  },
  "firestore": {
    "/recordings/{recordingId}": {
      "schema": {
        "$ref": "#/backend/entities/Recording"
      },
      "description": "Collection of recordings to be assessed by users."
    },
    "/submissions/{submissionId}": {
      "schema": {
        "$ref": "#/backend/entities/AssessmentSubmission"
      },
      "description": "Store user assessment results."
    }
  }
}
